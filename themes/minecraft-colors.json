{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Minecraft Bedrock Colors",
  "author": "topfafi",
  "themes": [
    {
      "name": "Minecraft Bedrock Dark",
      "appearance": "dark",
      "style": {
        "background": "#2b2b2b",
        "editor.background": "#1e1e1e",
        "editor.foreground": "#d4d4d4",
        "editor.line_number": "#858585",
        "editor.active_line_number": "#c6c6c6",
        "terminal.background": "#1e1e1e",
        "terminal.foreground": "#d4d4d4",
        "syntax": {
          "color.black":       { "color": "#4a4a4a", "font_weight": 700 },
          "color.dark_blue":   { "color": "#0000AA" },
          "color.dark_green":  { "color": "#00AA00" },
          "color.dark_aqua":   { "color": "#00AAAA" },
          "color.dark_red":    { "color": "#AA0000" },
          "color.dark_purple": { "color": "#AA00AA" },
          "color.gold":        { "color": "#FFAA00" },
          "color.gray":        { "color": "#AAAAAA" },
          "color.dark_gray":   { "color": "#555555" },
          "color.blue":        { "color": "#5555FF" },
          "color.green":       { "color": "#55FF55" },
          "color.aqua":        { "color": "#55FFFF" },
          "color.red":         { "color": "#FF5555" },
          "color.light_purple":{ "color": "#FF55FF" },
          "color.yellow":      { "color": "#FFFF55" },
          "color.white":       { "color": "#FFFFFF" },
          "color.minecoin":    { "color": "#DDD605" },

          "format.bold":          { "color": "#FFD700", "font_weight": 700 },
          "format.italic":        { "color": "#C0C0C0", "font_style": "italic" },
          "format.underline":     { "color": "#87CEEB" },
          "format.strikethrough": { "color": "#808080" },
          "format.obfuscated":    { "color": "#FF69B4" },
          "format.reset":         { "color": "#666666", "font_style": "normal", "font_weight": 400 },

          "variable": { "color": "#CE9178" },
          "escape":   { "color": "#888888" },
          "text":     { "color": "#D4D4D4" },

          "comment":  { "color": "#6A9955" },
          "keyword":  { "color": "#569CD6" },
          "string":   { "color": "#CE9178" },
          "function": { "color": "#DCDCAA" },
          "number":   { "color": "#B5CEA8" },
          "type":     { "color": "#4EC9B0" },
          "operator": { "color": "#D4D4D4" }
        }
      }
    },
    {
      "name": "Minecraft Bedrock Light",
      "appearance": "light",
      "style": {
        "background": "#f5f5f5",
        "editor.background": "#ffffff",
        "editor.foreground": "#333333",
        "editor.line_number": "#999999",
        "editor.active_line_number": "#333333",
        "terminal.background": "#ffffff",
        "terminal.foreground": "#333333",
        "syntax": {
          "color.black":       { "color": "#000000", "font_weight": 700 },
          "color.dark_blue":   { "color": "#0000AA" },
          "color.dark_green":  { "color": "#00AA00" },
          "color.dark_aqua":   { "color": "#00AAAA" },
          "color.dark_red":    { "color": "#AA0000" },
          "color.dark_purple": { "color": "#AA00AA" },
          "color.gold":        { "color": "#FFAA00" },
          "color.gray":        { "color": "#AAAAAA" },
          "color.dark_gray":   { "color": "#555555" },
          "color.blue":        { "color": "#5555FF" },
          "color.green":       { "color": "#00CC00" },
          "color.aqua":        { "color": "#00AAAA" },
          "color.red":         { "color": "#FF5555" },
          "color.light_purple":{ "color": "#FF55FF" },
          "color.yellow":      { "color": "#CCCC00" },
          "color.white":       { "color": "#888888" },
          "color.minecoin":    { "color": "#BBB005" },

          "format.bold":          { "color": "#CC8800", "font_weight": 700 },
          "format.italic":        { "color": "#555555", "font_style": "italic" },
          "format.underline":     { "color": "#4488AA" },
          "format.strikethrough": { "color": "#808080" },
          "format.obfuscated":    { "color": "#CC44AA" },
          "format.reset":         { "color": "#999999", "font_style": "normal", "font_weight": 400 },

          "variable": { "color": "#A31515" },
          "escape":   { "color": "#777777" },
          "text":     { "color": "#333333" },

          "comment":  { "color": "#008000" },
          "keyword":  { "color": "#0000FF" },
          "string":   { "color": "#A31515" },
          "function": { "color": "#795E26" },
          "number":   { "color": "#098658" },
          "type":     { "color": "#267f99" },
          "operator": { "color": "#333333" }
        }
      }
    }
  ]
}
