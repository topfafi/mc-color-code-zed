{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Minecraft Bedrock Colors",
  "author": "topfafi",
  "themes": [
    {
      "name": "Minecraft Bedrock Dark",
      "appearance": "dark",
      "style": {
        "background": "#1a1a2e",
        "editor.background": "#0f0f1a",
        "editor.foreground": "#d4d4d4",
        "editor.line_number": "#555577",
        "editor.active_line_number": "#9999bb",
        "editor.selection.background": "#264f78",
        "editor.active_line.background": "#1a1a2e",
        "terminal.background": "#0f0f1a",
        "terminal.foreground": "#d4d4d4",

        "syntax": {
          "mc.black":       { "color": "#000000" },
          "mc.dark_blue":   { "color": "#0000AA" },
          "mc.dark_green":  { "color": "#00AA00" },
          "mc.dark_aqua":   { "color": "#00AAAA" },
          "mc.dark_red":    { "color": "#AA0000" },
          "mc.dark_purple": { "color": "#AA00AA" },
          "mc.gold":        { "color": "#FFAA00" },
          "mc.gray":        { "color": "#AAAAAA" },
          "mc.dark_gray":   { "color": "#555555" },
          "mc.blue":        { "color": "#5555FF" },
          "mc.green":       { "color": "#55FF55" },
          "mc.aqua":        { "color": "#55FFFF" },
          "mc.red":         { "color": "#FF5555" },
          "mc.light_purple":{ "color": "#FF55FF" },
          "mc.yellow":      { "color": "#FFFF55" },
          "mc.white":       { "color": "#FFFFFF" },
          "mc.minecoin":    { "color": "#DDD605" },

          "mc.bold":        { "color": "#FFFFFF", "font_weight": 700 },
          "mc.italic":      { "color": "#DDDDDD", "font_style": "italic" },
          "mc.underline":   { "color": "#AADDFF" },
          "mc.strike":      { "color": "#888888" },
          "mc.obfuscate":   { "color": "#FF55FF" },
          "mc.reset":       { "color": "#888888" },

          "variable.special": { "color": "#CE9178" },
          "string.escape":    { "color": "#777777" },
          "text.literal":     { "color": "#D4D4D4" }
        }
      }
    },
    {
      "name": "Minecraft Bedrock Light",
      "appearance": "light",
      "style": {
        "background": "#f0f0f5",
        "editor.background": "#ffffff",
        "editor.foreground": "#333333",
        "editor.line_number": "#aaaaaa",
        "editor.active_line_number": "#555555",
        "editor.selection.background": "#add6ff",
        "editor.active_line.background": "#f5f5ff",
        "terminal.background": "#ffffff",
        "terminal.foreground": "#333333",

        "syntax": {
          "mc.black":       { "color": "#111111" },
          "mc.dark_blue":   { "color": "#0000AA" },
          "mc.dark_green":  { "color": "#007700" },
          "mc.dark_aqua":   { "color": "#007777" },
          "mc.dark_red":    { "color": "#AA0000" },
          "mc.dark_purple": { "color": "#AA00AA" },
          "mc.gold":        { "color": "#BB7700" },
          "mc.gray":        { "color": "#777777" },
          "mc.dark_gray":   { "color": "#444444" },
          "mc.blue":        { "color": "#3333CC" },
          "mc.green":       { "color": "#007700" },
          "mc.aqua":        { "color": "#007799" },
          "mc.red":         { "color": "#CC2222" },
          "mc.light_purple":{ "color": "#AA00AA" },
          "mc.yellow":      { "color": "#999900" },
          "mc.white":       { "color": "#888888" },
          "mc.minecoin":    { "color": "#998800" },

          "mc.bold":        { "color": "#111111", "font_weight": 700 },
          "mc.italic":      { "color": "#333333", "font_style": "italic" },
          "mc.underline":   { "color": "#2255AA" },
          "mc.strike":      { "color": "#999999" },
          "mc.obfuscate":   { "color": "#AA00AA" },
          "mc.reset":       { "color": "#999999" },

          "variable.special": { "color": "#A31515" },
          "string.escape":    { "color": "#888888" },
          "text.literal":     { "color": "#333333" }
        }
      }
    }
  ]
}
