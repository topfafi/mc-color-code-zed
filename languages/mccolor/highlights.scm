(seg_aqua)         @mc.aqua
(seg_red)          @mc.red
(seg_light_purple) @mc.light_purple
(seg_yellow)       @mc.yellow
(seg_white)        @mc.white
(seg_minecoin)     @mc.minecoin

(seg_bold)         @mc.bold
(seg_italic)       @mc.italic
